<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Reporte de Transferencias</title>
    <style>
        @page { size: letter portrait; margin: 30px; }
        body { font-family: 'Helvetica', Arial, sans-serif; color: #333; margin: 0; box-sizing: border-box; font-size: 11px; }
        table { width: 100%; border-collapse: collapse; }
        
        .header-table { width: 100%; margin-bottom: 5px; }
        .logo-box { border: 2px solid #00605A; padding: 10px; text-align: center; color: #00605A; width: 80px; font-weight: bold; border-radius: 5px; }
        .logo-text { font-size: 24px; font-weight: bold; line-height: 1; }
        .title-text { 
            font-size: 20px; 
            color: #00605A;
            font-weight: bold;
            padding-left: 20px; 
            vertical-align: middle;
            text-transform: uppercase;
        }
        .subtitle { color: #666; font-size: 12px; margin-top: 5px; font-weight: normal; }
        
        .divider { height: 2px; background-color: #00605A; width: 100%; margin-bottom: 20px; }
        
        .main-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        .main-table th { background-color: #00605A; color: white; padding: 8px; text-align: left; font-size: 10px; text-transform: uppercase; border: 1px solid #004b46; }
        .main-table td { border: 1px solid #ddd; padding: 8px; vertical-align: top; }
        .main-table tr:nth-child(even) { background-color: #f9f9f9; }
        
        .status { font-weight: bold; }
        .status-Aprobada { color: #10b981; }
        .status-Rechazada { color: #ef4444; }
        .status-Pendiente { color: #f59e0b; }
        
        .footer { position: fixed; bottom: -10px; left: 0px; right: 0px; height: 30px; font-size: 9px; color: #666; text-align: center; border-top: 1px solid #ddd; padding-top: 5px; }
    </style>
</head>
<body>

<table class="header-table">
    <tr>
        <td style="width: 100px;">
            <img src="data:image/png;base64," style="height: 60px; width: auto;" alt="CPS Logo">
        </td>
        <td class="title-text">
            REPORTE DE TRANSFERENCIAS
            <div class="subtitle">
                Periodo: {{ periodo|capitalize }} ({{ fechaInicio|date('d/m/Y') }} - {{ fechaFin|date('d/m/Y') }})
                {% if centro %}
                    | Filtrado por Centro: {{ centro.nombre }}
                {% else %}
                    | Global (Todos los centros)
                {% endif %}
            </div>
        </td>
    </tr>
</table>
<div class="divider"></div>

<table class="main-table">
    <thead>
        <tr>
            <th style="width: 12%">ID / Fecha</th>
            <th style="width: 25%">Origen</th>
            <th style="width: 25%">Destino</th>
            <th style="width: 10%">Equipos</th>
            <th style="width: 15%">Estado</th>
            <th style="width: 13%">Solicitante</th>
        </tr>
    </thead>
    <tbody>
        {% for t in transferencias %}
            <tr>
                <td>
                    <strong>TRF-{{ '%04d'|format(t.id) }}</strong><br>
                    {{ t.fechaTransferencia ? t.fechaTransferencia|date('d/m/Y') : '-' }}
                </td>
                <td>
                    <strong>{{ t.centroOrigen ? t.centroOrigen.nombre : '-' }}</strong>
                    {% if t.seccionOrigen %}
                        <br><span style="color: #666; font-size: 9px;">Sec: {{ t.seccionOrigen.nombre }}</span>
                    {% endif %}
                </td>
                <td>
                    <strong>{{ t.centroDestino ? t.centroDestino.nombre : '-' }}</strong>
                    {% if t.seccionDestino %}
                        <br><span style="color: #666; font-size: 9px;">Sec: {{ t.seccionDestino.nombre }}</span>
                    {% endif %}
                </td>
                <td style="text-align: center; font-weight: bold; font-size: 14px;">
                    {{ t.items|length }}
                </td>
                <td>
                    <span class="status status-{{ t.estado }}">{{ t.estado }}</span>
                    {% if t.fechaAprobacion %}
                        <br><span style="font-size: 9px; color: #666;">{{ t.fechaAprobacion|date('d/m/y') }}</span>
                    {% endif %}
                </td>
                <td>{{ t.solicitante ? t.solicitante.email : '-' }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" style="text-align: center; padding: 20px; font-style: italic; color: #666;">No hay transferencias registradas en este periodo.</td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<div class="footer">
    Sistema de Gestión de Equipos - Caja Petrolera de Salud | Generado el {{ 'now'|date('d/m/Y H:i') }}
</div>

</body>
</html>
