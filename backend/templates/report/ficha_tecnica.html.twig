<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Ficha Técnica - {{ equipo.nombre }}</title>
    <style>
        body { font-family: 'Helvetica', sans-serif; margin: 0; padding: 20px; color: #333; font-size: 12px; }
        .header { display: table; width: 100%; border-bottom: 2px solid #115e59; padding-bottom: 10px; margin-bottom: 20px; }
        .header-logo { display: table-cell; vertical-align: middle; width: 60px; }
        .header-logo img { width: 50px; height: auto; }
        .header-title { display: table-cell; vertical-align: middle; }
        .header-title h1 { color: #115e59; font-size: 20px; margin: 0; padding: 0; }
        .header-title h2 { color: #64748b; font-size: 14px; margin: 5px 0 0 0; padding: 0; font-weight: normal; }
        
        .section-title { background-color: #f1f5f9; color: #0f172a; padding: 8px 12px; margin-top: 20px; margin-bottom: 10px; font-weight: bold; border-left: 4px solid #0d9488; font-size: 14px; text-transform: uppercase;}
        
        table.info-table { width: 100%; border-collapse: collapse; margin-bottom: 15px; }
        table.info-table th, table.info-table td { border: 1px solid #e2e8f0; padding: 8px 10px; text-align: left; vertical-align: top;}
        table.info-table th { background-color: #f8fafc; color: #475569; width: 25%; font-weight: bold; font-size: 11px; text-transform: uppercase;}
        table.info-table td { color: #0f172a; width: 25%; font-size: 13px;}
        
        table.data-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        table.data-table th, table.data-table td { border: 1px solid #cbd5e1; padding: 8px; text-align: left; font-size: 12px; }
        table.data-table th { background-color: #0f172a; color: white; font-weight: bold; }
        table.data-table tr:nth-child(even) { background-color: #f8fafc; }
        
        .badge { display: inline-block; padding: 3px 6px; font-size: 10px; font-weight: bold; border-radius: 4px; color: #fff;}
        .badge-success { background-color: #10b981; }
        .badge-warning { background-color: #f59e0b; }
        .badge-danger { background-color: #ef4444; }
        .badge-neutral { background-color: #64748b; }
        
        .footer { position: fixed; bottom: -20px; left: 0; right: 0; height: 30px; text-align: center; color: #94a3b8; font-size: 10px; border-top: 1px solid #e2e8f0; padding-top: 5px; }
        
        .page-break { page-break-after: always; }
        .empty-message { text-align: center; color: #94a3b8; font-style: italic; padding: 15px; border: 1px dashed #cbd5e1; background: #f8fafc; }
    </style>
</head>
<body>

<div class="header">
    <div class="header-title">
        <h1>Caja Petrolera de Salud</h1>
        <h2>Ficha Técnica de Equipo: {{ equipo.nombre }}</h2>
    </div>
    <div style="display: table-cell; text-align: right; vertical-align: middle; color: #64748b; font-size: 11px;">
        Código: <strong>{{ equipo.codigoInventario|default('S/C') }}</strong><br>
        Fecha Impresión: {{ fecha|date('d/m/Y H:i') }}
    </div>
</div>

<div class="section-title">Datos Generales del Equipo</div>
<table class="info-table">
    <tr>
        <th>Nombre Comercial</th>
        <td colspan="3" style="font-weight: bold; font-size: 14px;">{{ equipo.nombre }}</td>
    </tr>
    <tr>
        <th>Código Inventario</th>
        <td>{{ equipo.codigoInventario|default('-') }}</td>
        <th>Categoría</th>
        <td>{{ equipo.categoria ? equipo.categoria.nombre : '-' }}</td>
    </tr>
    <tr>
        <th>Marca</th>
        <td>{{ equipo.marca|default('-') }}</td>
        <th>Modelo</th>
        <td>{{ equipo.modelo|default('-') }}</td>
    </tr>
    <tr>
        <th>Número de Serie</th>
        <td>{{ equipo.numeroSerie|default('-') }}</td>
        <th>Fecha Adquisición</th>
        <td>{{ equipo.fechaAdquisicion ? equipo.fechaAdquisicion|date('d/m/Y') : '-' }}</td>
    </tr>
</table>

<div class="section-title">Ubicación y Estado Físico</div>
<table class="info-table">
    <tr>
        <th>Centro Asignado</th>
        <td colspan="3">{{ equipo.centro ? equipo.centro.nombre : 'Sin Centro (Global)' }}</td>
    </tr>
    <tr>
        <th>Sección / Área</th>
        <td colspan="3">{{ equipo.seccion ? equipo.seccion.nombre : 'General' }}</td>
    </tr>
    <tr>
        <th>Estado Físico Reportado</th>
        <td>
            {% if equipo.estado %}
                <span style="font-weight:bold; color: #0f172a;">{{ equipo.estado.nombre }}</span>
            {% else %}
                -
            {% endif %}
        </td>
        <th>Observaciones</th>
        <td>{{ equipo.observaciones|default('Sin observaciones generales.') }}</td>
    </tr>
</table>

{% if componentes|length > 0 %}
<div class="section-title">Componentes Internos y Partes</div>
<table class="data-table">
    <thead>
        <tr>
            <th width="20%">Tipo de Componente</th>
            <th width="35%">Descripción</th>
            <th width="20%">Número de Serie</th>
            <th width="15%">Estado</th>
            <th width="10%">Instalación</th>
        </tr>
    </thead>
    <tbody>
        {% for c in componentes %}
        <tr>
            <td><strong>{{ c.tipoComponente ? c.tipoComponente.nombre : 'General' }}</strong></td>
            <td>{{ c.descripcion|default('-') }}</td>
            <td>{{ c.numeroSerie|default('-') }}</td>
            <td>
                {% if c.estado == 'Instalado' or c.estado == 'Nuevo' or c.estado == '1 - Nuevo' %}
                    <span class="badge badge-success">{{ c.estado }}</span>
                {% elseif c.estado == 'Dañado' or c.estado == 'Obsoleto' %}
                    <span class="badge badge-danger">{{ c.estado }}</span>
                {% else %}
                    <span class="badge badge-neutral">{{ c.estado }}</span>
                {% endif %}
            </td>
            <td>{{ c.fechaInstalacion ? c.fechaInstalacion|date('d/m/y') : '-' }}</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}

<div class="section-title">Historial de Mantenimientos</div>
{% if historiales|length > 0 %}
<table class="data-table">
    <thead>
        <tr>
            <th width="12%">Fecha</th>
            <th width="15%">Tipo</th>
            <th width="43%">Descripción del Trabajo / Fallo</th>
            <th width="15%">Técnico</th>
            <th width="15%">Estado Mantenimiento</th>
        </tr>
    </thead>
    <tbody>
        {% for h in historiales %}
        <tr>
            <td>{{ h.fechaMantenimiento ? h.fechaMantenimiento|date('d/m/Y') : '-' }}</td>
            <td>{{ h.tipoMantenimiento }}</td>
            <td>
                <strong>Fallo:</strong> {{ h.descripcionFallo|default('-') }}<br>
                <strong>Trabajo:</strong> {{ h.trabajoRealizado|default('-') }}
            </td>
            <td>{{ h.tecnicoResponsable ? h.tecnicoResponsable.nombre : 'Externo' }}</td>
            <td>
                {% if h.estado == 'Completado' %}
                    <span style="color:#10b981; font-weight:bold;">Completado</span>
                {% else %}
                    <span style="color:#f59e0b; font-weight:bold;">{{ h.estado }}</span>
                {% endif %}
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% else %}
<div class="empty-message">No se registran mantenimientos para este equipo.</div>
{% endif %}


<div class="section-title">Historial de Transferencias y Movimientos</div>
{% if transferencias|length > 0 %}
<table class="data-table">
    <thead>
        <tr>
            <th width="15%">Fecha</th>
            <th width="35%">Origen</th>
            <th width="35%">Destino</th>
            <th width="15%">Estado Traslado</th>
        </tr>
    </thead>
    <tbody>
        {% for t in transferencias %}
        <tr>
            <td>
                {% if t.transferencia and t.transferencia.fechaTransferencia %}
                    {{ t.transferencia.fechaTransferencia|date('d/m/Y') }}
                {% elseif t.transferencia and t.transferencia.fechaSolicitud %}
                    {{ t.transferencia.fechaSolicitud|date('d/m/Y') }} (Sol.)
                {% else %}
                    -
                {% endif %}
            </td>
            <td>
                {{ t.transferencia and t.transferencia.centroOrigen ? t.transferencia.centroOrigen.nombre : '' }}
                {{ t.transferencia and t.transferencia.seccionOrigen ? ' / ' ~ t.transferencia.seccionOrigen.nombre : '' }}
                {% if not t.transferencia or (not t.transferencia.centroOrigen and not t.transferencia.seccionOrigen) %}
                    Desconocido
                {% endif %}
            </td>
            <td>
                {{ t.transferencia and t.transferencia.centroDestino ? t.transferencia.centroDestino.nombre : '' }}
                {{ t.transferencia and t.transferencia.seccionDestino ? ' / ' ~ t.transferencia.seccionDestino.nombre : '' }}
                {% if not t.transferencia or (not t.transferencia.centroDestino and not t.transferencia.seccionDestino) %}
                    Desconocido
                {% endif %}
            </td>
            <td>
                {% if t.transferencia %}
                    {% if t.transferencia.estado == 'Completada' %}
                        <span style="color:#10b981; font-weight:bold;">Completada</span>
                    {% elseif t.transferencia.estado == 'Rechazada' %}
                        <span style="color:#ef4444; font-weight:bold;">Rechazada</span>
                    {% else %}
                        <span style="color:#f59e0b; font-weight:bold;">{{ t.transferencia.estado }}</span>
                    {% endif %}
                {% else %}
                    -
                {% endif %}
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% else %}
<div class="empty-message">No se registran traslados para este equipo.</div>
{% endif %}

<div class="footer">
    Documento generado por SisEquipos - Sistema de Gestión de Mantenimiento e Inventario. Página 1 de 1.
</div>

</body>
</html>
